            for event, league, gmt_time, href in matches:
                try:
                    gmt_clean = gmt_time.replace('GMT', '').strip()
                    dt        = datetime.strptime(gmt_clean, '%H:%M').replace(tzinfo=timezone.utc)
                    time_str  = dt.astimezone().strftime('%I:%M %p').lstrip('0')
                except Exception:
                    time_str = gmt_time.strip()
                full_url = urljoin(base, href)
                title    = f'[COLOR dodgerblue]{league.strip()} {time_str}[/COLOR] - [COLOR orange]{event.strip()}[/COLOR]'
                results.append((full_url, title))
            return results or None
