    @_guard
    def streamcenter(self, url):
        try:
            page_data = requests.get(url, timeout=TIMEOUT).json()
            results   = []
            for item in page_data:
                name  = item.get('name') or item.get('gameName') or 'Unknown'
                video = item.get('videoUrl') or ''
                start = item.get('beginPartie') or ''
                try:
                    t     = datetime.fromisoformat(start).replace(tzinfo=timezone.utc)
                    local = t.astimezone() - timedelta(hours=1)
                    start = local.strftime('%m/%d %I:%M %p').lstrip('0')
                except Exception:
                    pass
                title = self._label(start, name) if start else name
                for n, u in enumerate(video.split(';'), 1):
                    href = u.split('<')[0].strip()
                    if not href:
                        continue
                    label = title if n == 1 else f'{title} [COLOR red](Stream {n})[/COLOR]'
                    results.append((href, label))
            return results or None
        except Exception as e:
            _log_error('streamcenter', url, e)
            return None

