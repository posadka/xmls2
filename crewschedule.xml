    @_guard
    def sportssonline(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            results   = []
            now       = datetime.now()
            for line in page_data.splitlines():
                line = line.strip()
                if not line:
                    continue
                m = re.match(r'^(\d{1,2}:\d{2})\s+(.+?)\s*\|\s*(https?://\S+)', line)
                if not m:
                    continue
                time_str = m.group(1)
                title    = html.unescape(m.group(2).strip())
                link     = m.group(3).strip()
                try:
                    utc_t    = datetime.strptime(time_str, '%H:%M').replace(
                        year=now.year, month=now.month, day=now.day,
                        tzinfo=timezone.utc
                    )
                    time_str = utc_t.astimezone().strftime('%I:%M %p').lstrip('0')
                except Exception:
                    pass
                results.append((link, self._label(time_str, title)))
            return results or None
        except Exception as e:
            _log_error('sportssonline', url, e)
            return None

    @_guard
    def ripplenetwork(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            results   = []
            now       = datetime.now()
            for line in page_data.splitlines():
                line = line.strip()
                if not line:
                    continue
                m = re.match(r'^(\d{1,2}:\d{2})\s+(.+?)\s*\|\s*(https?://\S+)', line)
                if not m:
                    continue
                time_str = m.group(1)
                title    = html.unescape(m.group(2).strip())
                link     = m.group(3).strip()
                try:
                    utc_t    = datetime.strptime(time_str, '%H:%M').replace(
                        year=now.year, month=now.month, day=now.day,
                        tzinfo=timezone.utc
                    )
                    time_str = utc_t.astimezone().strftime('%I:%M %p').lstrip('0')
                except Exception:
                    pass
                results.append((link, self._label(time_str, title)))
            return results or None
        except Exception as e:
            _log_error('ripplenetwork', url, e)
            return None

    @_guard
    def sharkstreams(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            base      = _base_url(url)
            matches   = re.findall(
                r'(?s)<div class="row">.*?'
                r'<span class="ch-date">([^<]+)</span>.*?'
                r'<span class="ch-category">([^<]+)</span>.*?'
                r'<span class="ch-name">([^<]+)</span>.*?'
                r"window\.open\(\s*'([^']+)'",
                page_data
            )
            results = []
            for dt_str, category, name, player_url in matches:
                dt_str   = dt_str.strip()
                category = html.unescape(category).strip()
                name     = html.unescape(name).strip()
                try:
                    dt       = datetime.strptime(dt_str, '%Y-%m-%d %H:%M:%S')
                    time_str = dt.strftime('%m/%d %I:%M %p').lstrip('0')
                except Exception:
                    time_str = dt_str
                label = f'[COLOR dodgerblue]{category} {time_str} ET[/COLOR] [COLOR orange]{name}[/COLOR]'
                results.append((urljoin(base, player_url), label))
            return results or None
        except Exception as e:
            _log_error('sharkstreams', url, e)
            return None
