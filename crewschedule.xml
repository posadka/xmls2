class streamer:

    def resolve(self, url):
        try:
            if 'crackstreams.me' in url or 'methstreams' in url:
                return self.crackstreams(url)

            if 'istreameast.app' in url:
                return self.streameast(url)

            if any(x in url for x in ['ovostreams.com', 'ovogoaal', 'ovogoal', 'ovo-gola']):
                return self.ovostreams(url)

            if 'chaturbate.com' in url:
                return self.chaturbate(url)

            if 'tvsportslive.fr' in url:
                return self.tvsportslive(url)

            if 'streambtw' in url:
                return self.streambtw(url)

            if 'fsportshd' in url:
                return self.fsportshd(url)

            if 'volokit' in url:
                return self.volokit(url)

            if 'streameast.ga' in url:
                return self.streameast_ga(url)

            if 'buffstreams' in url:
                return self.buffstreams(url)

        except:
            return

    def streameast(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'(?s)<li class="f1-podium--item[^"]*">\s*<a\s+href="([^"]+)".*?<span[^>]*f1-podium--rank[^>]*>([^<]+)</span>.*?<span[^>]*d-md-inline[^>]*>\s*([^<]+?)\s*</span>', page_data, re.S)
            return [(i[0], html.unescape(i[1]), html.unescape(i[2])) for i in matches]
        except:
            return

    def crackstreams(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r"<a href='([^']*)(?:.*?heading'>)([^<]*).*?p>([^<]*)", page_data, re.S)
        except:
            return

    def ovostreams(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r"a href='([^']*).*?ing'>([^<]*)", page_data, re.S)
            return [('https://ovogoaal.com' + i[0], i[1]) for i in matches]
        except:
            return

    def chaturbate(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'<li.*?href="([^"]*)"(?:[^>]*)>([^<]*)', page_data, re.S)
            hosts = ['WOMEN', 'MEN', 'TRANS', 'COUPLES', 'FEATURED']
            return [
                ('https://chaturbate.com' + i[0], i[1])
                for i in matches
                if any(x in i[1] for x in hosts)
            ]
        except:
            return

    def hdrez(self, url):
        try:
            u = client.request(url)
            items = re.findall(r'<script>var.*?=\s*(\[[^;]+)', u)[0]
            items = re.findall(r'"(.+?)"', items)
            subitem = int(re.findall(r'\(atob.+?-\s*(\d+)', u)[0])
            srp = ''
            for item in items:
                srp += chr(
                    int(re.sub(r'[^\d]', '', base64.b64decode(item).decode('utf-8'))) - subitem)
            return re.findall(r'kode_ticket_text.*?h6>([^<]*).*?h2>([^<]*).*?an>([^<]*).*?h2>([^<]*).*?ef="([^"]*)',srp,re.S)
        except:
            return

    def fsportshd(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r'<div class="media-body">\s*<a\s+href="([^"]+)".*?>.*?<h4[^>]*>\s*([^<]+?)\s*</h4>',page_data,re.S)
        except:
            return

    def streambtw(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r'(?s)id":"item.*?title":"([^"]*)".*?:"([^"]*)', page_data)
        except:
            return

    def volokit(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'(?s)padding:0">([^<]*).*?href="([^"]*)', page_data)
            return [(html.unescape(i[0]),i[1])for i in matches]
        except:
            return

    def streameast_ga(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r'<a href="([^"]+)"\s*class="uefa-card[\s\S]*?<span class="uefa-name">\s*([^<]+?)\s*<\/span>[\s\S]*?<span class="uefa-name">\s*([^<]+?)\s*<\/span>[\s\S]', page_data)
        except:
            return

    def buffstreams(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(
                r'(?s)<a[^>]+class="competition"[^>]+title="([^"]+)"[^>]+href="([^"]+)".*?datetime="([^"]+)".*?status">([^<]*)',
                page_data
            )
            results = []
            for title, link, dt_str, display_time in matches:
                try:
                    dt_utc = datetime.strptime(dt_str, "%Y-%m-%d %H:%M:%S")
                    dt_local = datetime.fromtimestamp(dt_utc.timestamp())
                    fixed_time = dt_local.strftime("%I:%M %p").lstrip("0")
                except:
                    fixed_time = display_time
                clean_title = html.unescape(title).replace('Buffstreams ', '').strip()
                results.append((clean_title, link, fixed_time))
            return results
        except:
            return