            matches = re.findall(
                r'(?s)<a class="btn btn-info btn-block"[^>]+href="([^"]+)"[^>]*>'
                r'.*?<div class="text-center">([^<]*)</div>'
                r'.*?<div[^>]+d-none d-md-inline[^>]*>([^<]+)</div>',
                page_data
