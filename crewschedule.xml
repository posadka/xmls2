            results = []
            for href, time_str, teams in matches:
                full_url = urljoin(base, href)
                time_str = time_str.strip()
                teams = html.unescape(teams).strip()
                try:
                    dt = datetime.strptime(time_str, '%Y-%m-%d %H:%M ET')
