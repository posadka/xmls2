    @_guard
    def shd(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            if not page_data:
                return None
            base    = _base_url(url)
            matches = re.findall(
                r'(?s)<tr>\s*'
                r'<td[^>]*><strong>([^<]+)</strong></td>.*?'
                r'<td[^>]*><strong>([^<]+)<strong></td>.*?'
                r'<td[^>]*><strong>([^<]+)</strong></td>.*?'
                r'<a href="([^"]+)"',
                page_data
