            matches = re.findall(
                r'(?s)<div class="stream-time">([^<]+)</div>.*?'
                r'<div class="stream-info">.*?<img[^>]+>\s*([^<]+)</div>.*?'
                r'onclick="window\.location\.href=[\'"]([^\'"]+)',
                page_data
            )
            results = []
            for time_str, title, href in matches:
