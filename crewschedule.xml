    def streameast_ga(self, url):
        try:
            page_data = requests.get(url).text
            parsed = urlparse(url)
            base = f'{parsed.scheme}://{parsed.netloc}'
            matches = re.findall(
                r'(?s)<a href="([^"]+)"\s*class="uefa-card[^>]*data-time="(\d+)".*?'
                r'<span class="uefa-name">\s*([^<]+?)\s*</span>.*?'
                r'<span class="uefa-name">\s*([^<]+?)\s*</span>',
                page_data
            )
            results = []
            now = datetime.now().date()
            tomorrow = now + timedelta(days=1)
            for href, ts, team1, team2 in matches:
                full_url = urljoin(base, href)
                dt = datetime.fromtimestamp(int(ts))
                event_date = dt.date()
                if event_date == now:
                    label = 'Today'
                elif event_date == tomorrow:
                    label = 'Tomorrow'
                else:
                    label = dt.strftime('%m-%d')
                time_str = f'{label} {dt.strftime("%I:%M %p").lstrip("0")}'
                team1 = html.unescape(team1).strip()
                team2 = html.unescape(team2).strip()
                title = f"{team1} vs {team2} {time_str}"
                results.append((full_url, title))
            return results
        except Exception as e:
            log(f'streameast_ga error: {e}')
            return None

