class streamer:

    def resolve(self, url):
        try:
            if 'istreameast.app' in url: u = self.streameast(url)
            elif 'chaturbate.com' in url: u = self.chaturbate(url)
            elif 'tvsportslive.fr' in url: u = self.tvsportslive(url)
            elif 'streambtw' in url: u = self.streambtw(url)
            elif 'fsportshd' in url: u = self.fsportshd(url)
            elif 'volokit' in url: u = self.volokit(url)
            elif 'streameast.ga' in url: u = self.streameast_ga(url)
            elif 'buffstreams' in url: u = self.buffstreams(url)
            elif 'shd247' in url: u = self.shd(url)
            elif 'streamcenter' in url: u = self.supersurge(url)
            elif 'waatk' in url: u = self.waatk(url)
            elif 'playoffsstream' in url: u = self.playoff(url)
            elif 'ccrackstreams.sbs' in url: u = self.crackstreams(url)
            elif any(x in url for x in ['streameast.gl', 'givemereddit', 'givemeredditstreams']): u = self.givemereddit(url)
            elif any(x in url for x in ['methstreams.ms', 'crackstreams.ms']): u = self.methstreams(url)
            elif any(x in url for x in ['ovostreams.com', 'ovogoaal', 'ovogoal', 'ovo-gola', 'orbixa.top', 'tiplink']): u = self.ovostreams(url)
            return u
        except:
            pass

    def streameast(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(
                r'(?s)<li class="f1-podium--item[^"]*">\s*<a href="([^"]+)".*?'
                r'f1-podium--rank[^>]*>([^<]+)</span>.*?'
                r'd-md-inline[^>]*>\s*([^<]+?)\s*</span>.*?'
                r'data-zaman="(\d+)"',
                page_data
            )
            results = []
            for href, league, teams, timestamp in matches:
                href = href.strip()
                league = html.unescape(league).strip()
                teams = html.unescape(teams).strip()
                try:
                    t = datetime.fromtimestamp(int(timestamp))
                    time_str = t.strftime('%I:%M %p')
                except:
                    time_str = timestamp
                results.append((href, league, teams, time_str))
            return results
        except Exception as e:
            log(f'streameast error: {e}')
            return None

    def ovostreams(self, url):
        try:
            page_data = client.request(url)
            parsed = urlparse(url)
            base = f'{parsed.scheme}://{parsed.netloc}'
            results = []
            for match in re.finditer(
                r'class="stream-info"[^>]*>.*?<img[^>]+>\s*([^<]+).*?href=\'([^\']+)\'',
                page_data, re.S
            ):
                title = html.unescape(match.group(1)).strip()
                full_url = urljoin(base, match.group(2))
                results.append((full_url, title))
            return results if results else None
        except Exception as e:
            log(f'ovostreams error: {e}')
            return None

    def chaturbate(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'<li.*?href="([^"]*)"(?:[^>]*)>([^<]*)', page_data, re.S)
            hosts = ['WOMEN', 'MEN', 'TRANS', 'COUPLES', 'FEATURED']
            return [
                ('https://chaturbate.com' + i[0], i[1])
                for i in matches
                if any(x in i[1] for x in hosts)
            ]
        except Exception as e:
            log(f'chaturbate error: {e}')
            return None

    def hdrez(self, url):
        try:
            page_data = client.request(url)
            items = re.findall(r'<script>var.*?=\s*(\[[^;]+)', page_data)[0]
            items = re.findall(r'"(.+?)"', items)
            subitem = int(re.findall(r'\(atob.+?-\s*(\d+)', page_data)[0])
            srp = ''
            for item in items:
                srp += chr(
                    int(re.sub(r'[^\d]', '', base64.b64decode(item).decode('utf-8'))) - subitem)
            return re.findall(r'kode_ticket_text.*?h6>([^<]*).*?h2>([^<]*).*?an>([^<]*).*?h2>([^<]*).*?ef="([^"]*)',srp,re.S)
        except Exception as e:
            log(f'hdrez error: {e}')
            return None

