class streamer:

    def resolve(self, url):
        try:
            if 'crackstreams.me' in url : u = self.crackstreams(url)
            elif 'istreameast.app' in url: u = self.streameast(url)
            elif any(x in url for x in ['ovostreams.com', 'ovogoaal', 'ovogoal', 'ovo-gola']): u = self.ovostreams(url)
            elif 'chaturbate.com' in url: u = self.chaturbate(url)
            elif 'tvsportslive.fr' in url: u = self.tvsportslive(url)
            elif 'streambtw' in url: u = self.streambtw(url)
            elif 'fsportshd' in url: u = self.fsportshd(url)
            elif 'volokit' in url: u = self.volokit(url)
            elif 'streameast.ga' in url: u = self.streameast_ga(url)
            elif 'buffstreams' in url: u = self.buffstreams(url)
            elif 'streameast.gl' in url: u = self.givemereddit(url)
            elif 'methstreams.ms' in url: u = self.methstreams(url)
            elif 'shd247' in url: u = self.shd(url)
            return u
        except:
            pass

    def streameast(self, url):
        try:
            if control.infoLabel('Container.PluginName') != 'plugin.video.thecrew': return
            page_data = client.request(url)
            matches = re.findall(
                r'(?s)<li class="f1-podium--item[^"]*">\s*<a href="([^"]+)".*?'
                r'f1-podium--rank[^>]*>([^<]+)</span>.*?'
                r'd-md-inline[^>]*>\s*([^<]+?)\s*</span>.*?'
                r'data-zaman="(\d+)"',
                page_data
            )
            results = []
            for href, league, teams, timestamp in matches:
                href = href.strip()
                league = html.unescape(league).strip()
                teams = html.unescape(teams).strip()
                try:
                    t = datetime.fromtimestamp(int(timestamp))
                    time_str = t.strftime('%I:%M %p')
                except:
                    time_str = timestamp
                results.append((href, league, teams, time_str))
            return results
        except:
            return

    def crackstreams(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r"<a href='([^']*)(?:.*?heading'>)([^<]*).*?p>([^<]*)", page_data, re.S)
        except:
            return

    def ovostreams(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r"a href='([^']*).*?ing'>([^<]*)", page_data, re.S)
            return [('https://ovogoaal.com' + i[0], i[1]) for i in matches]
        except:
            return

    def chaturbate(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'<li.*?href="([^"]*)"(?:[^>]*)>([^<]*)', page_data, re.S)
            hosts = ['WOMEN', 'MEN', 'TRANS', 'COUPLES', 'FEATURED']
            return [
                ('https://chaturbate.com' + i[0], i[1])
                for i in matches
                if any(x in i[1] for x in hosts)
            ]
        except:
            return

    def hdrez(self, url):
        try:
            u = client.request(url)
            items = re.findall(r'<script>var.*?=\s*(\[[^;]+)', u)[0]
            items = re.findall(r'"(.+?)"', items)
            subitem = int(re.findall(r'\(atob.+?-\s*(\d+)', u)[0])
            srp = ''
            for item in items:
                srp += chr(
                    int(re.sub(r'[^\d]', '', base64.b64decode(item).decode('utf-8'))) - subitem)
            return re.findall(r'kode_ticket_text.*?h6>([^<]*).*?h2>([^<]*).*?an>([^<]*).*?h2>([^<]*).*?ef="([^"]*)',srp,re.S)
        except:
            return

    def fsportshd(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r'<div class="media-body">\s*<a\s+href="([^"]+)".*?>.*?<h4[^>]*>\s*([^<]+?)\s*</h4>',page_data,re.S)
        except:
            return

    def streambtw(self, url):
        try:
            page_data = client.request(url)
            return re.findall(r'(?s)id":"item.*?title":"([^"]*)".*?:"([^"]*)', page_data)
        except:
            return

    def volokit(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'(?s)padding:0">([^<]*).*?href="([^"]*)', page_data)
            return [(html.unescape(i[0]),i[1])for i in matches]
        except:
            return

    def streameast_ga(self, url):
        try:
            page_data = requests.get(url).text
            r = re.findall(
                r'(?s)<a href="([^"]+)"\s*class="uefa-card[^>]*data-time="(\d+)".*?'
                r'<span class="uefa-name">\s*([^<]+?)\s*</span>.*?'
                r'<span class="uefa-name">\s*([^<]+?)\s*</span>',
                page_data
            )
            results = []
            now = datetime.now().date()
            for href, ts, team1, team2 in r:
                dt = datetime.fromtimestamp(int(ts))
                event_date = dt.date()
                if event_date == now:
                    label = 'Today'
                elif event_date == now.replace(day=now.day + 1):
                    label = 'Tomorrow'
                else:
                    label = dt.strftime('%m-%d')
                time_str = f'{label} {dt.strftime("%I:%M %p").lstrip("0")}'
                results.append((href, team1.strip(), team2.strip(), time_str))
            return results
        except:
            return

    def buffstreams(self, url):
        try:
            page_data = client.request(url)
            matches = re.findall(r'(?s)<a[^>]+class="competition"[^>]+title="([^"]+)"[^>]+href="([^"]+)"',page_data)
            return [(html.unescape(i[0]).replace('Buffstreams ', '').strip(), i[1])for i in matches]
        except:
            return

    def roxiestreams(self, url):
        try:
            page_data = client.request(url)
            r = re.findall(
                r'(?s)<a href="([^"]+)">\s*([^<]+)</a>.*?<td>\s*([^<]+)</td>', page_data)
            out = []
            for link, name, timestr in r:
                try:
                    dt = datetime.strptime(timestr.strip(), "%B %d, %Y %I:%M %p")
                    dt = dt + timedelta(hours=3)
                    timestr = dt.strftime("%B %d, %Y %I:%M %p")
                except:
                    pass
                name = html.unescape(name)
                out.append((link, name.strip(), timestr.strip()))
            return out
        except:
            return

    def givemereddit(self, url):
        try:
            page_data = client.request(url)
            parsed = urlparse(url)
            base = f'{parsed.scheme}://{parsed.netloc}'
            r = re.findall(r'(?s)<a href="([^"]+)" class="matches".*?team-name">([^<]+).*?team-name">([^<]+)',page_data)
            results = []
            for href, team1, team2 in r:
                full_url = urljoin(base, href)
                team1 = html.unescape(team1)
                team2 = html.unescape(team2)
                results.append((full_url, team1.strip(), team2.strip()))
            return results
        except:
            return

    def methstreams(self, url):
        try:
            page_data = client.request(url)
            parsed = urlparse(url)
            base = f'{parsed.scheme}://{parsed.netloc}'
            r = re.findall(r'(?s)<a class="card" href="([^"]+)".*?title">([^<]*)</.*?time([^<]+)', page_data)
            results = []
            for href, teams, time in r:
                full_url = urljoin(base, href)
                teams = html.unescape(teams).strip()
