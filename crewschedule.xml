    @_guard
    def hdrez(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            items     = re.findall(r'<script>var.*?=\s*(\[[^;]+)', page_data)[0]
            items     = re.findall(r'"(.+?)"', items)
            subitem   = int(re.findall(r'\(atob.+?-\s*(\d+)', page_data)[0])
            srp       = ''
            for item in items:
                srp += chr(
                    int(re.sub(r'[^\d]', '', base64.b64decode(item).decode('utf-8'))) - subitem
                )
            results = re.findall(
                r'kode_ticket_text.*?h6>([^<]*).*?h2>([^<]*).*?an>([^<]*).*?h2>([^<]*).*?ef="([^"]*)',
                srp, re.S
            )
            return results or None
        except Exception as e:
            _log_error('hdrez', url, e)
            return None

    @_guard
    def fsportshd(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            base      = _base_url(url)
            matches   = re.findall(
                r'<div class="media-body">\s*<a href=["\']([^"\']+)["\'][^>]*>.*?'
                r'<h4[^>]*>\s*([^<]+?)\s*<\/h4>(.*?)<\/a>',
                page_data, re.S
            )
            results = []
            for href, teams, block in matches:
                if 'Click Here' in teams:
                    continue
                teams    = html.unescape(teams).strip()
                full_url = urljoin(base, href)
                dt_match = re.search(r"timeTo\(new Date\('([^']+)'\)", block)
                if dt_match:
                    try:
                        dt       = datetime.strptime(dt_match.group(1), '%b %d %Y %H:%M:%S +00:00')
                        dt       = dt.replace(tzinfo=timezone.utc).astimezone()
                        time_str = dt.strftime('%m/%d %I:%M %p').lstrip('0')
                    except Exception:
                        time_str = ''
                else:
                    time_str = 'Live'
                results.append((full_url, self._label(time_str, teams)))
            return results or None
        except Exception as e:
            _log_error('fsportshd', url, e)
            return None

