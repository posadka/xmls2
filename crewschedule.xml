    def shd(self, url):
        try:
            parsed = urlparse(url)
            base = f'{parsed.scheme}://{parsed.netloc}/'
            page_data = client.request(url)
            if not page_data:
                return
            matches = re.findall(
                r'(?s)<tr>\s*'
                r'<td[^>]*><strong>([^<]+)</strong></td>.*?'
                r'<td[^>]*><strong>([^<]+)</strong></td>.*?'
                r'<td[^>]*><strong>([^<]+)</strong></td>.*?'
                r'<a href="([^"]+)"',
                page_data
            )
            results = []
            for event, league, gmt_time, link in matches:
                try:
                    gmt_time_clean = gmt_time.replace('GMT', '').strip()
                    dt = datetime.strptime(gmt_time_clean, "%H:%M")
                    offset = datetime.now() - datetime.utcnow()
                    local_dt = dt + offset
                    time_str = local_dt.strftime("%I:%M %p")
                except:
                    time_str = gmt_time.strip()
                full_url = urljoin(base, link)
                results.append((full_url, league, event, time_str))
            return results
        except Exception as e:
            log(f'shd error: {e}')
            return None

    def supersurge(self, url):
        try:
            page_data = requests.get(url, timeout=5).json()
            results = []
            for i in page_data:
                name = i.get("name") or i.get("gameName") or "Unknown"
                video = i.get("videoUrl") or ""
                start = i.get("beginPartie") or ""
                try:
                    t = datetime.fromisoformat(start).replace(tzinfo=timezone.utc)
                    local = t.astimezone()
                    start = local.strftime("%I:%M %p")
                except:
                    pass
                title = f"{start} - {name}" if start else name
                for n, u in enumerate(video.split(';'), 1):
                    href = u.split('<')[0].strip()
                    if not href:
                        continue
                    label = title if n == 1 else f"{title} (Stream {n})"
                    results.append((href, label))
            return results
        except Exception as e:
            log(f'supersurge error: {e}')
            return None

