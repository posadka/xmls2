    def hdstreams(self, url):
        try:
            page_data = client.request(url)
            r = re.findall('(?s)0; text-decoration: underline;">([^<]*)|(?:>|>\s)(\d+:\d+)(?:.*?n>)([^<]*)(?:[^"]*)"([^"]*)', page_data)
            return r
        except:
