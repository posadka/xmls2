    @_guard
    def streameast_ga(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            base      = _base_url(url)
            now       = datetime.now().date()
            tomorrow  = now + timedelta(days=1)

            def _date_label(ts):
                dt         = datetime.fromtimestamp(int(ts))
                event_date = dt.date()
                if event_date == now:
                    day = 'Today'
                elif event_date == tomorrow:
                    day = 'Tomorrow'
                else:
                    day = dt.strftime('%m-%d')
                return f'{day} {dt.strftime("%I:%M %p").lstrip("0")}'

            matches = re.findall(
                r'(?s)<div class="m-card[^"]*"[^>]*data-time="(\d+)"[^>]*data-team-names="([^"]+)"[^>]*>.*?'
                r'<a class="m-card__link"\s+href="([^"]+)"',
                page_data
            )
            results = []
            for ts, team_names, href in matches:
                time_str  = _date_label(ts)
                teams     = team_names.split('|')
                team1     = html.unescape(teams[0]).strip() if len(teams) > 0 else ''
                team2     = html.unescape(teams[1]).strip() if len(teams) > 1 else ''
                label_txt = f'{team1} vs {team2}' if team2 else team1
                label     = f'[COLOR dodgerblue]{time_str}[/COLOR] [COLOR orange]{label_txt}[/COLOR]'
                results.append((urljoin(base, href), label))
            if not results:
                log('streameast_ga: no matches found', xbmc.LOGERROR)
                return None
            return results
        except Exception as e:
            _log_error('streameast_ga', url, e)
            return None

