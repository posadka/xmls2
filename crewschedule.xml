    @staticmethod
    def _fmt_utc_ts(ts, fmt='%m/%d %I:%M %p'):
        try:
            dt = datetime.fromtimestamp(int(ts), tz=timezone.utc).astimezone()
            return dt.strftime(fmt).lstrip('0')
        except Exception:
            return ''

    @staticmethod
    def _fmt_utc_dt(dt_str, in_fmt='%Y-%m-%d %H:%M:%S', out_fmt='%m/%d %I:%M %p'):
        try:
            dt = datetime.strptime(dt_str, in_fmt).replace(tzinfo=timezone.utc).astimezone()
            return dt.strftime(out_fmt).lstrip('0')
        except Exception:
            return ''

    @staticmethod
    def _label(time_str, title):
        if time_str:
            return f'[COLOR dodgerblue]{time_str}[/COLOR] [COLOR orange]{title}[/COLOR]'
        return f'[COLOR orange]{title}[/COLOR]'

    @_guard
    def streameast(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            matches = re.findall(
                r'(?s)<li class="f1-podium--item[^"]*">\s*<a href="([^"]+)".*?'
                r'f1-podium--rank[^>]*>([^<]+)</span>.*?'
                r'd-md-inline[^>]*>\s*([^<]+?)\s*</span>.*?'
                r'data.*?>([^<]*)',
                page_data
            )
            results = []
            for href, league, teams, timestamp in matches:
                href      = href.strip()
                league    = html.unescape(league).strip()
                teams     = html.unescape(teams).strip()
                timestamp = html.unescape(timestamp).strip()
                title     = f'[COLOR dodgerblue]{league} {timestamp}[/COLOR] [COLOR orange]{teams}[/COLOR]'
                results.append((href, title))
            return results or None
        except Exception as e:
            _log_error('streameast', url, e)
            return None

    @_guard
    def ovostreams(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
