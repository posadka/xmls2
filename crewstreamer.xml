            if not m:
                log(f'waatk no iframe at {url}')
                return
            iframe_url = m.group(1)
            iframe_html = requests.get(iframe_url, headers=headers).text
            m = re.search(r'fid\s*=\s*"([^"]+)"', iframe_html)
            if not m:
                log(f'waatk no fid at {iframe_url}')
                return
            fid = m.group(1)
            m = re.search(r'(?s)fid\s*=\s*.*?src=["\']([^"\']+)["\']', iframe_html)
            if not m:
                log(f'waatk no js src at {iframe_url}')
                return
            js_src = m.group(1)
            if js_src.startswith('//'):
                js_src = 'https:' + js_src
            parsed_js = urlparse(js_src)
            js_referer = f'{parsed_js.scheme}://{parsed_js.netloc}'
            js_headers = {'Referer': js_referer, 'User-Agent': UA}
            js_html = requests.get(js_src, headers=js_headers).text
            m = re.search(r'src=["\']([^"\']+)["\']', js_html)
            if not m:
                log(f'waatk no api src in js')
                return
            api = m.group(1)
            if api.startswith('//'):
                api = 'https:' + api
            elif api.startswith('/'):
                api = urljoin(js_referer, api)
            api_url = api + 'mobile&live=' + fid
            api_html = requests.get(api_url, headers=js_headers).text
            m = re.search(r'function\s+\w+\s*\(\s*\)\s*\{\s*return\s*\(\[([^\]]+)\]\.join\(""\)', api_html)
            if not m:
                log(f'waatk no join array in api response')
                return
            chars = re.findall(r'"([^"]*)"', m.group(1))
            source = ''.join(chars).replace(r'\/', '/')
            return (
                source
                + '|Referer=' + quote_plus(js_referer + '/')
                + '&Origin=' + quote_plus(js_referer)
                + '&User-Agent=' + quote_plus(UA)
            )
