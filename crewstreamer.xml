    def meth(self, url):
        try:
            if control.infoLabel('Container.PluginName') != 'plugin.video.thecrew': return
            page = client.request(url)
            def get_iframe_src(data):
                m = re.search(r'<iframe[^>]+(?:src|data-src)=["\']([^"\']+)', data, re.I)
                if not m:
                    return None
                src = m.group(1).strip()
                return "https:" + src if src.startswith("//") else src
            matches = list(re.finditer(
                r'https:\\/\\/(?:sharkstreams\.net\\/player\.php\?channel=\d+|streams\.center\\/embed\\/ch\d+\.php)',
                page
            ))
            if not matches:
                return
            links = []
            for i, m in enumerate(matches, 1):
                raw = m.group(0).replace('\\/', '/')
                if 'sharkstreams.net' in raw:
                    label = 'Link %s - SharkStreams' % i
                    source = 'shark'
                elif 'streams.center' in raw:
                    label = 'Link %s - Streams.center' % i
                    source = 'streams'
                else:
                    continue
                links.append((label, source, raw))
            if not links:
                return
            if len(links) == 1:
                choice = 0
            else:
                choice = xbmcgui.Dialog().select('Choose Stream', [x[0] for x in links])
            if choice == -1:
                return
            picked = links[choice]
            source = picked[1]
            picked_url = picked[2]
            if source == 'shark':
                json_url = picked_url

                json_data = requests.get(
                    json_url,
                    headers={'User-Agent': UA, 'Referer': url}
                ).text
                m = re.search(r"fetch\('([^']+)", json_data)
                if not m:
                    return
                fetch_path = m.group(1)
                api_url = 'https://sharkstreams.net/' + fetch_path
                api_data = requests.get(
                    api_url,
                    headers={'User-Agent': UA, 'Referer': json_url}
                ).text
                m = re.search(r'\["([^"]+)', api_data)
                if not m:
                    return
                final_url = m.group(1).replace('\\', '')
                refer = api_url + '/'
                origin = '/'.join(api_url.split('/', 3)[:3])
                return f"{final_url}|User-Agent={UA}&Referer={refer}&Origin={origin}"
            if source == 'streams':
                iframe1 = picked_url
                iframe1_html = requests.get(
                    iframe1,
                    headers={'User-Agent': UA, 'Referer': url}
                ).text
                iframe2 = get_iframe_src(iframe1_html)
                if not iframe2:
                    return
                iframe2_html = requests.get(
                    iframe2,
                    headers={"Referer": iframe1, "User-Agent": UA}
