TAG = 'Streamer'

MEDIA_EXTS = {'mp4', 'flv', 'm3u8'}


def log(msg, level=xbmc.LOGINFO):
    xbmc.log(f'{TAG} {msg}', level)


def _base_url(url):
    parsed = urlparse(url)
    return f'{parsed.scheme}://{parsed.netloc}'


def _is_media(url):
    return (urlparse(url).path).strip('/').split('/')[-1].split('.')[-1] in MEDIA_EXTS


def _guard(func):
    def wrapper(self, url):
        if control.infoLabel('Container.PluginName') != 'plugin.video.thecrew':
            return None
        return func(self, url)
    wrapper.__name__ = func.__name__
    return wrapper


class streamer:

    def _get_iframe_src(self, data, require_id=False):
        pattern = (
            r'<iframe\s*id="iframe[^>]+(?:src|data-src)=["\']([^"\']+)'
            if require_id else
            r'<iframe[^>]+(?:src|data-src)=["\']([^"\']+)'
        )
        m = re.search(pattern, data, re.I)
        if not m:
            return None
        src = m.group(1).strip()
        return 'https:' + src if src.startswith('//') else src

    @staticmethod
    def _join_array(api_html):
        m = re.search(r'\(\[([^\]]+)\]\.join\(""\)', api_html)
        if not m:
            return None
        chars  = re.findall(r'"([^"]*)"', m.group(1))
        source = ''.join(chars).replace(r'\/', '/')
        return re.sub(r'(https://)/{1,}', r'\1', source)

    @staticmethod
    def _decrypt_streams_center(html, referer):
        m = re.search(r'input:\s*"([^"]+)"', html)
        if not m:
            return None
        parsed = urlparse(referer)
        origin = f'{parsed.scheme}://{parsed.netloc}/'
        resp = requests.post(
            urljoin(origin, 'embed/decrypt.php'),
            data={'input': m.group(1)},
            headers={
                'User-Agent': UA,
                'Content-Type': 'application/x-www-form-urlencoded',
                'Referer': referer,
            },
            timeout=10
        ).text.strip()
        if not resp or not resp.startswith('http'):
            return None
        return f'{resp}|Referer={origin}&User-Agent={UA}'

