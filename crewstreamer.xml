                api_url  = f'https://stellarthread.com/wiki.php?player=mobile&live={fid}'
                api_html = requests.get(
                    api_url,
                    headers={'Referer': 'https://wikisport.club/', 'User-Agent': UA},
                    timeout=TIMEOUT
                ).text
                source = self._join_array(api_html)
                if not source:
                    return None
                return f'{source}|User-Agent={UA}&Referer=https://stellarthread.com/&Origin=https://stellarthread.com'

            iframe_html = requests.get(
                iframe_url,
                headers={'User-Agent': UA, 'Referer': url},
                timeout=TIMEOUT
            ).text
            if not iframe_html:
                return None
            origin = _base_url(iframe_url)

            if 'atob' in iframe_html:
                m = re.search(r"atob\(['\"]([^'\"]+)", iframe_html)
                if m:
                    decoded = base64.b64decode(m.group(1)).decode('utf-8', 'ignore')
                    return f'{decoded}|User-Agent={UA}&Referer={origin}/&Origin={origin}'

            m = re.search(r'source\s*[:=]\s*[\'"]([^\'"]+)', iframe_html)
            if m:
                return f'{m.group(1)}|User-Agent={UA}&Referer={origin}/&Origin={origin}'

            return self.embedsports(iframe_url)
