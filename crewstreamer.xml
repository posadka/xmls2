    def _get_iframe_src(self, data):
        m = re.search(r'<iframe[^>]+(?:src|data-src)=["\']([^"\']+)', data, re.I)
        if not m:
            return None
        src = m.group(1).strip()
        return "https:" + src if src.startswith("//") else src

    def _streams_center(self, iframe_url, referer):
        try:
            iframe_html = requests.get(
                iframe_url,
                headers={"Referer": referer, "User-Agent": UA}
            ).text
            m = re.search(r'input:\s*"([^"]+)"', iframe_html)
            if not m:
                return None
            token = m.group(1)
            hls_url = requests.post(
                "https://streams.center/embed/decrypt.php",
                data={"input": token},
                headers={
                    "User-Agent": UA,
                    "Content-Type": "application/x-www-form-urlencoded",
                    "Referer": iframe_url
                },
                timeout=10
            ).text.strip()
            return f"{hls_url}|Referer=https://streams.center/&User-Agent={UA}"
