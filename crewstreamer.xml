    @_guard
    def waatk(self, url):
        try:
            base    = _base_url(url)
            headers = {'Referer': base, 'User-Agent': UA}
            page_data = requests.get(url, headers=headers, timeout=10).text
            m = re.search(r'<iframe[^>]+src="([^"]+)"', page_data, re.I)
            if not m:
                log(f'waatk no iframe at {url}', xbmc.LOGERROR)
                return None
            iframe_url  = m.group(1)
            iframe_html = requests.get(iframe_url, headers=headers, timeout=10).text
            m = re.search(r'fid\s*=\s*"([^"]+)"', iframe_html)
            if not m:
                log(f'waatk no fid at {iframe_url}', xbmc.LOGERROR)
                return None
            fid = m.group(1)
            m   = re.search(r'(?s)fid\s*=\s*.*?src=["\']([^"\']+)["\']', iframe_html)
            if not m:
                log(f'waatk no js src at {iframe_url}', xbmc.LOGERROR)
                return None
            js_src = m.group(1)
            if js_src.startswith('//'):
                js_src = 'https:' + js_src
            js_origin  = _base_url(js_src)
            js_headers = {'Referer': js_origin, 'User-Agent': UA}
            js_html    = requests.get(js_src, headers=js_headers, timeout=10).text
            m          = re.search(r'src=["\']([^"\']+)["\']', js_html)
            if not m:
                log('waatk no api src in js', xbmc.LOGERROR)
                return None
            api = m.group(1)
            if api.startswith('//'):
                api = 'https:' + api
            elif api.startswith('/'):
                api = urljoin(js_origin, api)
            api_url  = api + 'mobile&live=' + fid
            api_html = requests.get(api_url, headers=js_headers, timeout=10).text
            m        = re.search(
                r'function\s+\w+\s*\(\s*\)\s*\{\s*return\s*\(\[([^\]]+)\]\.join\(""\)',
                api_html
            )
            if not m:
                log('waatk no join array in api response', xbmc.LOGERROR)
                return None
            chars  = re.findall(r'"([^"]*)"', m.group(1))
            source = ''.join(chars).replace(r'\/', '/')
            return (
                source
                + '|Referer=' + quote_plus(js_origin + '/')
                + '&Origin='  + quote_plus(js_origin)
                + '&User-Agent=' + quote_plus(UA)
            )
        except Exception as e:
            log(f'waatk failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def crackstreams(self, url):
        try:
            def xor_decode(data, key):
                return ''.join(chr(ord(c) ^ ord(key[i % len(key)])) for i, c in enumerate(data))
            page_data = client.request(url)
            key_m     = re.search(r'var _k="([^"]+)"', page_data)
            raw_m     = re.search(r'var _raw="([^"]+)"', page_data)
            if not key_m or not raw_m:
                return None
            key   = key_m.group(1)
            raw   = raw_m.group(1)
            d     = base64.b64decode(raw).decode()
            xd    = xor_decode(d, key)
            mid   = len(xd) // 2
            j     = base64.b64decode(base64.b64encode(xd[:mid].encode())).decode() + \
                    base64.b64decode(base64.b64encode(xd[mid:].encode())).decode()
            final = xor_decode(j, key)
            embed_url  = _base_url(url) + final
            embed_html = requests.get(
                embed_url,
                headers={'User-Agent': UA, 'Referer': url},
                timeout=10
            ).text
            iframe1 = self._get_iframe_src(embed_html)
            if not iframe1:
                return None
            iframe1_html = requests.get(
                iframe1,
                headers={'Referer': embed_url, 'User-Agent': UA},
                timeout=10
            ).text
            iframe2 = self._get_iframe_src(iframe1_html)
            if not iframe2:
                return None
            iframe2_html = requests.get(
                iframe2,
                headers={'Referer': iframe1, 'User-Agent': UA},
                timeout=10
            ).text
            return self._decrypt_streams_center(iframe2_html, iframe2)
        except Exception as e:
            log(f'crackstreams failed for {url} | {e}', xbmc.LOGERROR)
            return None

