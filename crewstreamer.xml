    @_guard
    def generic(self, url):
        try:
            r = client.request(url)
            r = r.replace('\\', '')

            patterns = [
                r"[0-9_']+:\s'([^']+)",
                r'\s*=\s*"(http.+?)"',
                r'\(\w+\("([^"]*)',
                r"\(\w+\('([^']*)",
                r'"\w+":"([^"]*)',
                r"'\w+':'([^']*)",
                r'\s*=\s*\'(http.+?)\'',
                r'\s*:\s*"(http.+?)"',
                r"\s*:\s*'(http.+?)'",
                r'\s*\(\s*"(http.+?)"',
                r"\s*\(\s*'(http.+?)'",
                r'\s*:\s*"(//.+?)"',
                r"\s*:\s*'(//.+?)'",
                r'\:"(\.+?)"',
                r":'(\.+?)'",
                r'\s*\(\s*"(//.+?)"',
                r"\s*\(\s*'(//.+?)'",
                r'\s*=\s*\'(//.+?)\'',
                r'\s*=\s*"(//.+?)"',
                r'\w*:\s*"(http.+?)"',
                r"\w*:\s*'(http.+?)'",
                r"\w*='([^']*)",
                r'\w*="([^"]*)',
                r"\w*\s*=\s*'([^']*)",
                r'\w*\s*=\s*"([^"]*)',
                r'(?s)<file>([^<]*)',
            ]

            s = []
            for pat in patterns:
                candidates = re.findall(pat, r)
                s += [i for i in candidates if _is_media(i)]
                if s:
                    break

            if not s:
                s = client.parseDOM(r, 'source', ret='src', attrs={'type': 'video.+?'})

            s = ['http:' + i if i.startswith('//') else i for i in s]
            s = [urljoin(url, i) if not i.startswith('http') else i for i in s]
            s = list(dict.fromkeys(s))

            self.u = []

            def request(i):
                try:
                    i = i.replace(' ', '%20')
                    c = client.request(i, output='headers')
                    checks = ['video', 'mpegurl', 'html', 'octet-stream']
                    if any(f in c['Content-Type'] for f in checks):
                        self.u.append((i, int(c.get('Content-Length', 0))))
                except Exception:
                    pass

            threads = [workers.Thread(request, i) for i in s]
            for t in threads:
                t.start()
            for t in threads:
                t.join()

            u = sorted(self.u, key=lambda x: x[1], reverse=True)
            if not u:
                return None
            return client.request(u[0][0], output='geturl', Referer=url)
        except Exception as e:
            log(f'generic failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def givemereddit(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=10).text
            m = re.search(r'(?is)iframe\s+class="embed-responsive-item"\s+src="([^"]+)"', page_data)
            if not m:
                return None
            iframe_url = m.group(1)
            if iframe_url.startswith('//'):
                iframe_url = 'https:' + iframe_url
            parsed  = urlparse(iframe_url)
            referer = f'{parsed.scheme}://{parsed.netloc}/'
            origin  = f'{parsed.scheme}://{parsed.netloc}'
            iframe_html = requests.get(
                iframe_url,
                headers={'Referer': referer, 'Origin': origin, 'User-Agent': UA},
                timeout=10
            ).text
            m = re.search(
                r'decodeURIComponent\(escape\(r\)\)}\("([^"]*)",([^,]*),"([^"]*)",([^,]*),([^,]*),([^)]+)\)',
                iframe_html
            )
            if not m:
                return None
            unpacked = hunter.hunter(
                m.group(1), int(m.group(2)), m.group(3),
                int(m.group(4)), int(m.group(5)), int(m.group(6))
            )
            m = re.search(r'src:\s*"([^"]+\.m3u8)"', unpacked)
            if not m:
                return None
            src = m.group(1).replace('\\', '')
            return (
                f'{src}'
                f'|Referer={referer}'
                f'&Origin={origin}'
                f'&User-Agent={UA}'
                f'&Accept=application/x-mpegURL,*/*'
            )
        except Exception as e:
            log(f'givemereddit failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def streameast(self, url):
        try:
            headers   = {'User-Agent': UA, 'Referer': url}
            page_data = requests.get(url, headers=headers, timeout=10).text
            m = re.search(r'(?is)<iframe[^>]+src="([^"]+)', page_data)
            if not m:
                return None
            iframe_url  = m.group(1)
            iframe_html = requests.get(iframe_url, headers=headers, timeout=10).text
            parsed  = urlparse(iframe_url)
            referer = f'{parsed.scheme}://{parsed.netloc}/'
            origin  = f'{parsed.scheme}://{parsed.netloc}'
            if 'atob' in iframe_html:
                m = re.search(r"atob\('([^']+)", iframe_html)
                if not m:
                    return None
                source = base64.b64decode(m.group(1)).decode('utf-8', 'ignore')
            else:
                m = re.search(r'const\s+source\s*=\s*"([^"]+)', iframe_html)
                if not m:
                    return None
                source = m.group(1)
            return f'{source}|User-Agent={UA}&Referer={referer}&Origin={origin}'
        except Exception as e:
            log(f'streameast failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def blacktienba(self, url):
        try:
            page_data    = requests.get(url, headers={'User-Agent': UA}, timeout=10).text
            base_headers = f'|User-Agent={UA}&Origin=http://blacktiesports.net&Referer='
            if 'm3u8' in page_data:
                m = re.search(r'(?:source|src|file):\s*[\'"]([^\'"]+)', page_data)
                if not m:
                    return None
                return m.group(1) + base_headers + url
            elif 'php' in page_data:
                m = re.search(r'(?s)<iframe id="stream.*?src="([^"]*)', page_data)
                if not m:
                    return None
                iframe_url  = m.group(1)
                iframe_html = client.request(iframe_url)
                m = re.search(r'<script>var.*?=\s*(\[[^;]+)', iframe_html)
                if not m:
                    return None
                items   = re.findall('"(.+?)"', m.group(1))
                m       = re.search(r'\(atob.+?-\s*(\d+)', iframe_html)
                if not m:
                    return None
                subitem = int(m.group(1))
                decoded = ''.join(
                    chr(int(re.sub(r'[^\d]', '', base64.b64decode(i).decode('utf-8'))) - subitem)
                    for i in items
                )
                m = re.search(r"atob\('([^']*)", decoded)
                if not m:
                    return None
                link = base64.b64decode(m.group(1).replace(' ', '')).decode('utf-8')
                return link + base_headers + iframe_url
            else:
                m = re.search(r'<script>var.*?=\s*(\[[^;]+)', page_data)
                if not m:
                    return None
                items   = re.findall('"(.+?)"', m.group(1))
                m       = re.search(r'\(atob.+?-\s*(\d+)', page_data)
                if not m:
                    return None
                subitem = int(m.group(1))
                decoded = ''.join(
                    chr(int(re.sub(r'[^\d]', '', base64.b64decode(i).decode('utf-8'))) - subitem)
                    for i in items
                )
                m = re.search(r'(?:source|src|file):\s*[\'"]([^\'"]+)', decoded)
                if not m:
                    return None
                return m.group(1).replace(' ', '') + base_headers + url
        except Exception as e:
            log(f'blacktienba failed for {url} | {e}', xbmc.LOGERROR)
            return None

