    @_guard
    def embedhd(self, url):
        try:
            origin  = _base_url(url)
            headers = {'Referer': origin, 'User-Agent': UA}
            page_data = requests.get(url, headers=headers, timeout=TIMEOUT).text
            m = re.search(r'fid\s*=\s*"([^"]+)"', page_data)
            if not m:
                return None
            fid = m.group(1)
            m   = re.search(r'(?s)fid\s*=\s*.*?src=["\']([^"\']+)["\']', page_data)
            if not m:
                return None
            js_src = m.group(1)
            if js_src.startswith('//'):
                js_src = 'https:' + js_src
            js_origin = _base_url(js_src)
            js_html   = requests.get(js_src, headers=headers, timeout=TIMEOUT).text
            m         = re.search(r'src=["\']([^"\']+)', js_html)
            if not m:
                return None
            api = m.group(1)
            if api.startswith('//'):
                api = 'https:' + api
            elif api.startswith('/'):
                api = urljoin(js_origin, api)
            api_url  = api + 'mobile&live=' + fid
            api_html = requests.get(api_url, headers=headers, timeout=TIMEOUT).text
            source   = self._join_array(api_html)
            if not source:
                return None
            return (
                source
                + '|Referer=' + quote_plus(js_origin + '/')
                + '&Origin='  + quote_plus(js_origin)
                + '&User-Agent=' + quote_plus(UA)
            )
        except Exception as e:
            _log_error('embedhd', url, e)
            return None

    @_guard
    def methstreams(self, url):
        try:
            page_data = requests.get(url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
            matches = list(re.finditer(
                r'https?:\\?/\\?/(?:sharkstreams\.net\\?/player\.php\?channel=\d+|streams\.center\\?/embed\\?/ch\d+\.php)',
                page_data
            ))
            if not matches:
                return None
            links = []
            for i, m in enumerate(matches, 1):
                raw = m.group(0).replace('\\/', '/')
                if 'sharkstreams.net' in raw:
                    links.append((f'Link {i} - SharkStreams', 'shark', raw))
                elif 'streams.center' in raw:
                    links.append((f'Link {i} - Streams.center', 'streams', raw))
            if not links:
                return None
            choice = 0 if len(links) == 1 else xbmcgui.Dialog().select('Choose Stream', [x[0] for x in links])
            if choice == -1:
                return None
            label, source, picked_url = links[choice]

            if source == 'shark':
                origin, referer = _origin_referer(picked_url)
                page_data = requests.get(
                    picked_url,
                    headers={'User-Agent': UA, 'Referer': url},
                    timeout=TIMEOUT
                ).text
                m = re.search(r"fetch\('([^']+)", page_data)
                if not m:
                    return None
                api_url  = urljoin(origin, m.group(1))
                api_data = requests.get(
                    api_url,
                    headers={'User-Agent': UA, 'Referer': picked_url},
                    timeout=TIMEOUT
                ).text
                try:
                    urls = json.loads(api_data).get('urls', [])
                except Exception:
                    m = re.search(r'\["([^"]+)', api_data)
                    if not m:
                        return None
                    urls = [m.group(1).replace('\\', '')]
                if not urls:
                    return None
                if len(urls) == 1:
                    stream = urls[0]
                else:
                    choice = xbmcgui.Dialog().select('Choose Stream', [f'Stream {i+1}' for i in range(len(urls))])
                    if choice == -1:
                        return None
                    stream = urls[choice]
                if not stream:
                    return None
                return f'{stream}|User-Agent={UA}&Referer={referer}&Origin={origin}'

            if source == 'streams':
                iframe1_html = requests.get(
                    picked_url,
                    headers={'User-Agent': UA, 'Referer': url},
                    timeout=TIMEOUT
                ).text
                iframe2 = self._get_iframe_src(iframe1_html)
                if not iframe2:
                    return None
                iframe2_html = requests.get(
                    iframe2,
                    headers={'Referer': picked_url, 'User-Agent': UA},
                    timeout=TIMEOUT
                ).text
                return self._decrypt_streams_center(iframe2_html, iframe2)
        except Exception as e:
            _log_error('methstreams', url, e)
            return None

    @_guard
    def roxiestreams(self, url):
        try:
            origin, referer = _origin_referer(url)
            headers = {'Referer': referer, 'User-Agent': UA}
            page_data = requests.get(url, headers=headers, timeout=TIMEOUT).text
            if not page_data:
                return None
            m3u8_list = []

            if 'getRandomStream' in page_data:
                stream_calls = set(re.findall(
                    r"getRandomStream\(\s*'([^']+)'\s*,\s*'([^']+)'\s*\)",
                    page_data
                ))
                fetch_m = re.search(r"fetch\('([^']+)", page_data)
                try:
                    domain_url  = urljoin(origin, fetch_m.group(1)) if fetch_m else None
                    domain_text = requests.get(domain_url, headers=headers, timeout=TIMEOUT).text
                    domains     = [d.strip() for d in domain_text.splitlines() if d.strip()]
                except Exception:
