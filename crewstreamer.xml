            m          = re.search(r'(?s)<iframe[^>]*allow=[\'"]encrypted-media[^>]*src=[\'"]([^\'"]+)', page_data)
            if not m:
                return None
            iframe_url = m.group(1)

            if 'embedhd' in iframe_url:
                return self.embedhd(iframe_url)

            elif 'wikisport' in iframe_url:
                iframe_html = requests.get(iframe_url, headers={'User-Agent': UA}, timeout=TIMEOUT).text
                m           = re.search(r'fid\s*=\s*"([^"]+)"', iframe_html)
                if not m:
                    return None
