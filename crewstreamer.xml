            headers     = {'Referer': iframe_url, 'User-Agent': UA}
            m           = re.search(r'<iframe[^>]+src="([^"]+)', iframe_html)
            if not m:
                return None
            iframe2_url = m.group(1)
            if iframe2_url.startswith('//'):
