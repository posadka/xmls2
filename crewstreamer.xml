    @_guard
    def embedsports(self, url):
        try:
            if not any(h in url for h in ('embedsports.top', 'pooembed', 'embedindia')):
                page_data = requests.get(url, headers={'User-Agent': UA, 'Referer': url}, timeout=TIMEOUT).text
                m = re.search(r'<iframe[^>]+src=["\']([^"\']*(?:embedsports\.top|pooembed)[^"\']+)', page_data, re.I)
                if not m:
                    log(f'embedsports no iframe found at {url}', xbmc.LOGERROR)
                    return None
                url = m.group(1).strip()
                if url.startswith('//'):
                    url = 'https:' + url

            url    = url.split('#')[0]
            origin = _base_url(url)
            host   = _up(url).netloc

            def _varint(n):
                out = bytearray()
                while True:
                    byte = n & 0x7F
                    n >>= 7
                    out.append(byte | 0x80 if n else byte)
                    if not n:
                        return bytes(out)

            def _field(number, value):
                tag = (number << 3) | 2
                return bytes([tag]) + _varint(len(value)) + value

            segments = url.rstrip('/').split('/')
            SINGLE_PATH_HOSTS = ('pooembed', 'embedindia')
            if any(h in host for h in SINGLE_PATH_HOSTS):
                path    = '/'.join(segments[4:])
                payload = _field(1, path.encode())
            else:
                sc, stream_id, no = segments[-3], segments[-2], segments[-1]
                payload = _field(1, sc.encode()) + _field(2, stream_id.encode()) + _field(3, no.encode())

            headers = {
                'indians':      '18866ebec06934ba03ad3387e9fc9ebfbf2ea2d0e9305c86797b66c62ee4f8a5',
                'content-type': 'application/octet-stream',
                'origin':       origin,
                'referer':      url,
                'user-agent':   UA,
            }
            fetch = requests.post(urljoin(origin, '/fetch'), data=payload, headers=headers, timeout=TIMEOUT)
            log(f'embedsports DEBUG status={fetch.status_code} headers={dict(fetch.headers)}', xbmc.LOGERROR)
            log(f'embedsports DEBUG content[:200]={fetch.content[:200]}', xbmc.LOGERROR)
            if not fetch.content:
                log(f'embedsports empty response for {url}', xbmc.LOGERROR)
                return None

            ac  = fetch.headers.get('access-control-expose-headers')
            key = fetch.headers.get(ac)
            if not key:
                log(f'embedsports missing key header for {url}', xbmc.LOGERROR)
                return None

            i = 0
            while i < len(fetch.content):
                tag   = fetch.content[i]
                i    += 1
                field = tag >> 3
                length = 0
                shift  = 0
                while True:
                    b      = fetch.content[i]
                    i     += 1
                    length |= (b & 0x7F) << shift
                    if not (b & 0x80):
                        break
                    shift += 7
                value = fetch.content[i:i + length]
                i    += length
                if field == 1:
                    b64_cipher = value
                    break
            else:
                log('embedsports no cipher field found', xbmc.LOGERROR)
                return None

            decoded = bytes(((b - 0x21 + 71) % 94) + 0x21 for b in b64_cipher)
            raw     = base64.b64decode(decoded + b'=' * (-len(decoded) % 4))
            nonce   = raw[:12]
            ct_with_tag = raw[12:]
            cipher  = ChaCha20_Poly1305.new(key=key.encode('utf-8'), nonce=nonce)
            stream_url = cipher.decrypt_and_verify(ct_with_tag[:-16], ct_with_tag[-16:]).decode('utf-8').strip()
            log(f'embedsports stream URL: {stream_url}')
            return (
                stream_url
                + '|User-Agent=' + UA
                + '&Referer=' + origin + '/'
                + '&Origin=' + origin
                + '&Accept=*/*'
                + '&Accept-Language=en-US,en;q=0.7'
                + '&Sec-Fetch-Dest=empty'
                + '&Sec-Fetch-Mode=cors'
                + '&Sec-Fetch-Site=cross-site'
                + '&Sec-GPC=1'
            )
        except Exception as e:
            _log_error('embedsports', url, e)
            return None

