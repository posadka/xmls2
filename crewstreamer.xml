                stream_url = m3u8_list[0]
            else:
                labels = [f'Stream {i + 1}' for i in range(len(m3u8_list))]
                choice = xbmcgui.Dialog().select('Select Stream', labels)
                if choice == -1:
                    return None
                stream_url = m3u8_list[choice]
            return f'{stream_url}|User-Agent={UA}&Referer={referer}&Origin={origin}'
        except Exception as e:
            log(f'roxiestreams failed for {url} | {e}', xbmc.LOGERROR)
            return None

