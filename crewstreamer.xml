    @_guard
    def embedsports(self, url):
        try:
            if 'embedsports.top' not in url:
                page_data = requests.get(url, headers={'User-Agent': UA, 'Referer': url}, timeout=10).text
                m         = re.search(r'<iframe[^>]+src=["\']([^"\']*embedsports\.top[^"\']+)', page_data, re.I)
                if not m:
                    log(f'embedsports no iframe found at {url}', xbmc.LOGERROR)
                    return None
                url = m.group(1).strip()
                if url.startswith('//'):
                    url = 'https:' + url
            url   = url.split('#')[0]
            parts = url.rstrip('/').split('/')
            if 'embed' in parts:
                idx       = parts.index('embed')
                stream_sc = parts[idx + 1]
                stream_id = parts[idx + 2] if len(parts) > idx + 2 else ''
                stream_no = parts[idx + 3] if len(parts) > idx + 3 else '1'
            else:
                if len(parts) < 3:
                    return None
                stream_sc, stream_id, stream_no = parts[-3], parts[-2], parts[-1]
            log(f'embedsports parts: sc={stream_sc!r} id={stream_id!r} no={stream_no!r}')
            payload   = bytes([
                0x0A, len(stream_sc), *stream_sc.encode('utf-8'),
                0x12, len(stream_id), *stream_id.encode('utf-8'),
                0x1A, len(stream_no), *stream_no.encode('utf-8'),
            ])
            parsed    = urlparse(url)
            origin    = f'{parsed.scheme}://{parsed.netloc}'
            fetch_url = f'{origin}/fetch'
            headers   = {
                'Content-Type': 'application/octet-stream',
                'Origin':       origin,
                'Referer':      url,
                'User-Agent':   UA,
            }
            fetch = requests.post(fetch_url, data=payload, headers=headers, timeout=10)
            if not fetch.content:
                log(f'embedsports empty response for {url}', xbmc.LOGERROR)
                return None
            i          = 1
            cipher_len = 0
            shift      = 0
            while i < len(fetch.content):
                b          = fetch.content[i]
                i         += 1
                cipher_len |= (b & 0x7F) << shift
                shift      += 7
                if not (b & 0x80):
                    break
            cipher  = fetch.content[i:i + cipher_len]
            decoded = bytes([x - 47 if x >= 0x50 else x + 47 for x in cipher])
            decoded += b'=' * (-len(decoded) % 4)
            b64     = base64.b64decode(decoded)
            aes_key = fetch.headers.get('Goat')
            if not aes_key:
                log(f'embedsports missing Goat header for {url}', xbmc.LOGERROR)
                return None
            aes       = AES.new(
                aes_key.encode(),
                AES.MODE_CTR,
                counter=Counter.new(128, initial_value=int.from_bytes(b'STOPSTOPSTOPSTOP', 'big'))
            )
            decrypted = aes.decrypt(b64).decode('utf-8')
            log(f'embedsports stream URL: {decrypted}')
            return f'{decrypted}|User-Agent={UA}&Referer={url}&Origin={origin}'
        except Exception as e:
            log(f'embedsports failed for {url} | {e}', xbmc.LOGERROR)
            return None

