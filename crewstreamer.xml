            m = re.search(r'zmid\s*=\s*"([^"]+)"', page_data)
            if not m:
                log(f'embedme no zmid at {url}', xbmc.LOGERROR)
                return
            zmid = m.group(1)
            m = re.search(r'gameCat\s*=\s*"([^"]+)"', page_data)
            if not m:
                log(f'embedme no gameCat at {url}', xbmc.LOGERROR)
                return
            game_cat = m.group(1)
            m = re.search(r'\bpid\s*=\s*(\d+)', page_data)
            pid = m.group(1) if m else '5'
            m = re.search(r'\bedm\s*=\s*"([^"]+)"', page_data)
            edm = m.group(1) if m else 'ninguno.net'
            m = re.search(r'const siteConfig\s*=\s*(\{[^;]+\})', page_data)
            if not m:
                log(f'embedme no siteConfig at {url}', xbmc.LOGERROR)
                return
            site_config = json.loads(m.group(1))
            csrf = site_config.get('csrf')
            csrf_ip = site_config.get('csrf_ip')
            if not csrf or not csrf_ip:
                log(f'embedme no csrf at {url}', xbmc.LOGERROR)
                return
            m = re.search(r'gameText\s*=\s*"([^"]+)"', page_data)
            game_text = m.group(1) if m else ''
            params = {
                'pid': pid,
                'gacat': game_text,
                'gatxt': game_cat,
                'v': zmid,
                'csrf': csrf,
                'csrf_ip': csrf_ip
            }
            embed_url = f"https://{edm}/sd0embed/{game_cat}?" + urlencode(params)
            embed_headers = {
                'User-Agent': UA,
                'Referer': origin + '/',
                'Origin': origin
            }
            embed_html = requests.get(embed_url, headers=embed_headers, timeout=10).text
            m = re.search(r"const videoUrl = '([^']+)'", embed_html)
            if not m:
                log(f'embedme no videoUrl at {embed_url}', xbmc.LOGERROR)
                return
            stream_url = base64.b64decode(base64.b64decode(m.group(1)).decode('utf-8')).decode('utf-8')
            m = re.search(r"const secTokenUrl = '([^']+)'", embed_html)
            if not m:
                log(f'embedme no secTokenUrl at {embed_url}', xbmc.LOGERROR)
                return
            auth_base = base64.b64decode(m.group(1)).decode('utf-8')
            m_scode = re.search(r"const sCode = '([^']+)'", embed_html)
            m_ts = re.search(r"const expireTs = ([^;]+);", embed_html)
            m_uid = re.search(r"const strUnqId = '([^']+)'", embed_html)
            if not (m_scode and m_ts and m_uid):
                log(f'embedme missing auth params at {embed_url}', xbmc.LOGERROR)
                return
            auth_url = f"{auth_base}/?stream={m_uid.group(1)}&scode={m_scode.group(1)}&expires={m_ts.group(1)}"
            requests.get(auth_url, headers={'Referer': embed_url, 'User-Agent': UA}, timeout=10)
            log(f'embedme stream URL: {stream_url}')
            return (
                stream_url
                + f"|User-Agent={UA}"
                + f"&Referer={embed_url}"
            )
        except Exception as e:
            log(f'embedme failed for {url} | {e}', xbmc.LOGERROR)

