    @_guard
    def naughtyblog(self, url):
        try:
            page_data = requests.get(url, timeout=10).text
            if not page_data:
                return None
            part = page_data.split('<strong>Download:', 1)
            if len(part) < 2:
                return None
            segment = part[1]
            part    = segment.split('<strong>Watch online:', 1)
            if len(part) > 1:
                segment = part[0]
            links   = re.findall(r'(?is)<a\s+href="([^"]+)"[^>]*>([^<]+)</a>', segment)
            hosts   = ['Rapidgator']
            results = [
                (href.strip(), f'[COLOR orange]{html.unescape(label.replace("Direct Link", "")).strip()}[/COLOR]')
                for href, label in links
                if any(h in href for h in hosts)
            ]
            if not results:
                return None
            if len(results) == 1:
                return results[0][0]
            choice = xbmcgui.Dialog().select('Choose Source', [r[1] for r in results])
            return results[choice][0] if choice != -1 else None
        except Exception as e:
            log(f'naughtyblog failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def embedhd(self, url):
        try:
            parsed  = urlparse(url)
            referer = f'{parsed.scheme}://{parsed.netloc}'
            headers = {'Referer': referer, 'User-Agent': UA}
            page_data = requests.get(url, headers=headers, timeout=10).text
            m = re.search(r'fid\s*=\s*"([^"]+)"', page_data)
            if not m:
                return None
            fid = m.group(1)
            m   = re.search(r'(?s)fid\s*=\s*.*?src=["\']([^"\']+)["\']', page_data)
            if not m:
                return None
            js_src   = m.group(1)
            full_url = 'https:' + js_src if js_src.startswith('//') else js_src
            parsed   = urlparse(full_url)
            referer  = f'{parsed.scheme}://{parsed.netloc}'
            js_data  = requests.get(full_url, headers=headers, timeout=10).text
            m        = re.search(r'src=["\']([^"\']+)', js_data)
            if not m:
                return None
            api = m.group(1)
            if api.startswith('//'):
                api = 'https:' + api
            elif api.startswith('/'):
                api = urljoin(referer, api)
            api_url  = api + 'mobile&live=' + fid
            api_html = requests.get(api_url, headers=headers, timeout=10).text
            source   = self._join_array(api_html)
            if not source:
                return None
            return (
                source
                + '|Referer=' + quote_plus(referer + '/')
                + '&Origin=' + quote_plus(referer)
                + '&User-Agent=' + quote_plus(UA)
            )
        except Exception as e:
            log(f'embedhd failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def methstreams(self, url):
        try:
            page = client.request(url)
            matches = list(re.finditer(
                r'https?:\\?/\\?/(?:sharkstreams\.net\\?/player\.php\?channel=\d+|streams\.center\\?/embed\\?/ch\d+\.php)',
                page
            ))
            if not matches:
                return None
            links = []
            for i, m in enumerate(matches, 1):
                raw = m.group(0).replace('\\/', '/')
                if 'sharkstreams.net' in raw:
                    links.append((f'Link {i} - SharkStreams', 'shark', raw))
                elif 'streams.center' in raw:
                    links.append((f'Link {i} - Streams.center', 'streams', raw))
            if not links:
                return None
            choice = 0 if len(links) == 1 else xbmcgui.Dialog().select('Choose Stream', [x[0] for x in links])
            if choice == -1:
                return None
            label, source, picked_url = links[choice]
            if source == 'shark':
                json_data = requests.get(
                    picked_url,
                    headers={'User-Agent': UA, 'Referer': url},
                    timeout=10
                ).text
                m = re.search(r"fetch\('([^']+)", json_data)
                if not m:
                    return None
                api_url  = 'https://sharkstreams.net/' + m.group(1)
                api_data = requests.get(
                    api_url,
                    headers={'User-Agent': UA, 'Referer': picked_url},
                    timeout=10
                ).text
                m = re.search(r'\["([^"]+)', api_data)
                if not m:
                    return None
                stream  = m.group(1).replace('\\', '')
                origin  = _base_url(api_url)
                referer = origin + '/'
                return f'{stream}|User-Agent={UA}&Referer={referer}&Origin={origin}'
            if source == 'streams':
                iframe1_html = requests.get(
                    picked_url,
                    headers={'User-Agent': UA, 'Referer': url},
                    timeout=10
                ).text
                iframe2 = self._get_iframe_src(iframe1_html)
                if not iframe2:
                    return None
                iframe2_html = requests.get(
                    iframe2,
                    headers={'Referer': picked_url, 'User-Agent': UA},
                    timeout=10
                ).text
                return self._decrypt_streams_center(iframe2_html, iframe2)
        except Exception as e:
            log(f'methstreams failed for {url} | {e}', xbmc.LOGERROR)
            return None

    @_guard
    def roxiestreams(self, url):
        try:
            parsed  = urlparse(url)
            referer = f'{parsed.scheme}://{parsed.netloc}/'
            origin  = f'{parsed.scheme}://{parsed.netloc}'
            headers = {'Referer': referer, 'User-Agent': UA}
            page_data = requests.get(url, headers=headers, timeout=10).text
            if not page_data:
                return None
            m3u8_list = []
            if 'getRandomStream' in page_data:
                stream_calls = set(re.findall(
                    r"getRandomStream\(\s*'([^']+)'\s*,\s*'([^']+)'\s*\)",
                    page_data
                ))
                fetch_m = re.search(r"fetch\('([^']+)", page_data)
                try:
                    domain_url  = urljoin(referer, fetch_m.group(1)) if fetch_m else None
                    domain_text = requests.get(domain_url, headers=headers, timeout=10).text
                    domains     = [d.strip() for d in domain_text.splitlines() if d.strip()]
                except Exception:
                    domains = ['shadow-ran.online']
                for stream_path, subdomain in stream_calls:
                    d = random.choice(domains)
                    m3u8_list.append(f'https://{subdomain}.{d}/{stream_path}')
            clappr = re.findall(r"showPlayer\([^,]+,\s*['\"]([^'\"]+\.m3u8)", page_data)
            if clappr:
                m3u8_list.extend(clappr)
            if not m3u8_list:
                m3u8_list = re.findall(r'https?://[^\s\'"]+\.m3u8', page_data, re.DOTALL)
